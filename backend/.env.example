PORT=5001
ADMIN_PASSWORD=change-me

# PocketBase — the backend talks to it as a superuser
POCKETBASE_URL=http://127.0.0.1:8090
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=change-me-too

# Resume uploads are stored on the local filesystem under backend/uploads/
# and served at /uploads — no extra configuration required.

# Gmail address used to send applicant/intern emails
EMAIL_USER=you@gmail.com
# Gmail App Password (https://myaccount.google.com/apppasswords)
EMAIL_PASS=your-app-password
EMAIL_FROM="GSPL Team" <you@gmail.com>
